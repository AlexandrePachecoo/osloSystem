# --- Banco (Supabase) ---
# URL pooled via Supavisor (transaction mode, porta 6543) — usada em runtime.
# Painel do Supabase: Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres"
# Conexão direta (porta 5432) — usada APENAS por `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres"

# --- Supabase (Storage etc., fases futuras) ---
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Crons ---
# Segredo que protege as rotas /api/cron/*. O Vercel Cron envia
# `Authorization: Bearer $CRON_SECRET` automaticamente quando esta env existe.
# Gere com: openssl rand -hex 32
CRON_SECRET=""

# Dias sem mudança de status para gerar lembrete (default 5)
LEMBRETE_DIAS_SEM_MUDANCA="5"

# --- Auth do admin (usuário único) ---
# Senha de login do painel
ADMIN_PASSWORD=""
# Segredo para assinar o cookie de sessão. Gere com: openssl rand -hex 32
AUTH_SECRET=""

# --- OpenAI (Fase 4) ---
OPENAI_API_KEY=""
