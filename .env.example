# --- Banco (Supabase) ---
# URL pooled via Supavisor (transaction mode, porta 6543) — usada em runtime.
# Painel do Supabase: Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres"
# Conexão direta (porta 5432) — usada APENAS por `prisma migrate`.
# Host diferente do pooler acima — painel: Settings > Database > Connection string > Direct connection
DIRECT_URL="postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres"

# --- Supabase (Storage etc., fases futuras) ---
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Crons ---
# Segredo que protege as rotas /api/cron/*. O Vercel Cron envia
# `Authorization: Bearer $CRON_SECRET` automaticamente quando esta env existe.
# Gere com: openssl rand -hex 32
CRON_SECRET=""

# Dias sem mudança de status para gerar lembrete (default 5)
LEMBRETE_DIAS_SEM_MUDANCA="5"

# --- Auth (2 papéis) ---
# Senha de login do painel completo (admin)
ADMIN_PASSWORD=""
# Senha de login da portaria (funcionário — só acessa /portaria).
# Opcional: vazia = login de funcionário desativado.
FUNCIONARIO_PASSWORD=""
# Segredo para assinar o cookie de sessão. Gere com: openssl rand -hex 32
AUTH_SECRET=""

# --- OpenAI (Fase 4) ---
# Opcional: sem a key, mensagens do WhatsApp entram na fila sem
# classificação/rascunho e o admin preenche manualmente.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- WhatsApp real via Meta Cloud API (Fase 6) ---
# Opcional. Deixe WHATSAPP_PROVIDER="mock" (default) para o canal só logar,
# sem enviar nada. Coloque "meta" para plugar a Meta Cloud API de verdade —
# nesse caso as variáveis abaixo passam a ser obrigatórias.
WHATSAPP_PROVIDER="mock"
# Access token PERMANENTE (System User token do Meta Business — não o de 24h).
WHATSAPP_ACCESS_TOKEN=""
# ID do número (Meta for Developers > WhatsApp > API Setup > Phone number ID).
WHATSAPP_PHONE_NUMBER_ID=""
# String arbitrária que você inventa; a Meta a envia de volta no handshake do
# webhook (GET). Configure a mesma no painel da Meta. Gere com: openssl rand -hex 16
WHATSAPP_VERIFY_TOKEN=""
# App Secret (Meta for Developers > Configurações > Básico). Usado para validar
# a assinatura X-Hub-Signature-256 de cada webhook recebido.
WHATSAPP_APP_SECRET=""
# Versão do Graph API (default v21.0).
WHATSAPP_GRAPH_VERSION="v21.0"
