generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7: as URLs de conexão não ficam no schema.
// - Runtime: adapter pg com DATABASE_URL (pooled, Supavisor 6543) em src/lib/prisma.ts
// - Migrations: DIRECT_URL (5432) configurada em prisma.config.ts
datasource db {
  provider = "postgresql"
}

enum Prioridade {
  baixa
  media
  alta
  urgente
}

enum ServicoStatus {
  orcamento
  aprovado
  em_andamento
  feito
  rejeitado
}

enum RascunhoStatus {
  pendente
  aprovado
  enviado
  descartado
}

enum FuncionarioStatus {
  ativo
  inativo
}

model Empresa {
  id          String    @id @default(cuid())
  nome        String
  contato     String?
  categoria   String?
  observacoes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  servicos    Servico[]
}

model Funcionario {
  id        String            @id @default(cuid())
  nome      String
  funcao    String
  contato   String?
  status    FuncionarioStatus @default(ativo)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ItemEstoque {
  id               String   @id @default(cuid())
  nome             String
  quantidade       Int      @default(0)
  quantidadeMinima Int      @default(0)
  unidade          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Servico {
  id              String             @id @default(cuid())
  titulo          String
  descricao       String?
  valorOrcamento  Decimal?           @db.Decimal(12, 2)
  prioridade      Prioridade         @default(media)
  status          ServicoStatus      @default(orcamento)
  statusChangedAt DateTime           @default(now())
  // Dias sem mudança de status até gerar novo lembrete.
  // null = usa o default global (LEMBRETE_DIAS_SEM_MUDANCA).
  lembreteDias    Int?
  empresaId       String?
  empresa         Empresa?           @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  // Empresa não cadastrada (texto livre) — ex.: orçamento avulso.
  // Ignorada quando empresaId está preenchido.
  empresaNome     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  statusLogs      ServicoStatusLog[]
  lembretes       Lembrete[]
  orcamentos      Orcamento[]

  @@index([status])
  @@index([statusChangedAt])
}

// Orçamentos concorrentes de um serviço — ex.: "vazamento na garagem" com
// propostas de empresas diferentes (empresa X por R$ Y, empresa A por R$ Z).
// Um deles pode ser marcado como selecionado (a proposta escolhida).
model Orcamento {
  id          String   @id @default(cuid())
  servicoId   String
  servico     Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  fornecedor  String // nome da empresa/fornecedor (texto livre)
  valor       Decimal  @db.Decimal(12, 2)
  observacoes String?
  selecionado Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([servicoId])
}

model ServicoStatusLog {
  id         String         @id @default(cuid())
  servicoId  String
  servico    Servico        @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  deStatus   ServicoStatus? // null no log de criação
  paraStatus ServicoStatus
  createdAt  DateTime       @default(now())

  @@index([servicoId])
}

model Lembrete {
  id        String   @id @default(cuid())
  // null = lembrete manual (criado pelo admin ou pelo assistente), sem serviço.
  servicoId String?
  servico   Servico? @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  mensagem  String
  resolvido Boolean  @default(false)
  // "Adiar": some das listas de ativos até esta data/hora, então reaparece.
  // null = nunca adiado. Não afeta o índice parcial (segue 1 ativo por serviço).
  adiadoAte DateTime?
  // "Agendar": lembrete criado para o futuro. Só entra nas listas de ativos
  // (painel/lembretes) a partir desta data. null = vale desde já. Mesma lógica
  // de exibição do adiadoAte; não afeta o índice parcial.
  agendadoPara DateTime?
  createdAt DateTime @default(now())

  // Índice parcial (1 lembrete NÃO resolvido por serviço) criado à mão na
  // migration: lembrete_um_ativo_por_servico. Prisma não expressa índice parcial.
  // NULLs não colidem no índice — lembretes manuais podem coexistir à vontade.
  @@index([resolvido])
  @@index([servicoId])
}

// Informações avulsas que alimentam a IA (assistente do painel e respostas do
// WhatsApp) — ex.: "festa junina no salão dia 12/09 às 19h". Desativar tira a
// nota do contexto sem apagar o histórico.
model NotaContexto {
  id        String   @id @default(cuid())
  texto     String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
}

model Relatorio {
  id            String   @id @default(cuid())
  periodoInicio DateTime
  periodoFim    DateTime
  dados         Json
  resumo        String
  createdAt     DateTime @default(now())

  // idempotência do cron semanal: 1 relatório por período
  @@unique([periodoInicio, periodoFim])
}

// --- Portaria (Fase 8) ---
// Diário da portaria preenchido pelo funcionário: ocorrências + encomendas.
// "Enviar para administração" fecha um RelatorioPortaria com o snapshot do
// momento; encomendas ainda não entregues NÃO são fechadas — seguem aparecendo
// nos próximos relatórios até a baixa.

enum EncomendaTipo {
  interna // morador retira / entrega no apto
  externa // alguém de fora retira — exige o nome de quem vai retirar
}

model OcorrenciaPortaria {
  id          String             @id @default(cuid())
  colaborador String // quem registrou (nome livre, sugerido dos funcionários ativos)
  texto       String
  // null = ainda não enviada — entra no relatório atual
  relatorioId String?
  relatorio   RelatorioPortaria? @relation(fields: [relatorioId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([relatorioId])
}

model EncomendaPortaria {
  id          String             @id @default(cuid())
  apto        String
  descricao   String
  tipo        EncomendaTipo      @default(interna)
  // Preenchido quando tipo = externa: nome de quem vai retirar
  retiradaPor String?
  colaborador String // quem registrou
  entregue    Boolean            @default(false)
  entregueEm  DateTime?
  // Relatório em que a ENTREGA foi reportada (só entregues são fechadas;
  // pendentes ficam sem relatório e reaparecem no próximo)
  relatorioId String?
  relatorio   RelatorioPortaria? @relation(fields: [relatorioId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([entregue])
  @@index([relatorioId])
}

model RelatorioPortaria {
  id          String               @id @default(cuid())
  colaborador String // quem enviou
  dados       Json // snapshot: ocorrências + encomendas (entregues e pendentes) no envio
  resumo      String // texto pronto para leitura/registro
  enviadoEm   DateTime             @default(now())
  ocorrencias OcorrenciaPortaria[]
  encomendas  EncomendaPortaria[]
}

// Jornais entregues nos apartamentos (ex.: Zero Hora, Correio do Povo). Cada
// jornal tem uma lista FIXA de apartamentos assinantes; a portaria marca no dia
// quais foram entregues (checkbox). O envio do relatório fecha o snapshot e
// zera as marcações para o próximo dia. `torre` agrupa como no relatório antigo.
model JornalPortaria {
  id        String               @id @default(cuid())
  nome      String
  torre     String? // ex.: "A", "B" — agrupamento no relatório
  ordem     Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  aptos     JornalAptoPortaria[]

  @@index([torre])
}

model JornalAptoPortaria {
  id        String         @id @default(cuid())
  jornalId  String
  jornal    JornalPortaria @relation(fields: [jornalId], references: [id], onDelete: Cascade)
  apto      String
  // Marcado no dia = entregue. Zera no envio do relatório.
  entregue  Boolean        @default(false)
  ordem     Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([jornalId])
}

model MensagemWhatsApp {
  id               String         @id @default(cuid())
  textoOriginal    String
  autor            String
  remetente        String?        // wa_id/telefone E.164 — destino da resposta (Cloud API)
  externalId       String?        @unique // id no provider — dedupe na ingestão
  prioridade       Prioridade?
  rascunhoResposta String?
  rascunhoStatus   RascunhoStatus @default(pendente)
  recebidaEm       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([rascunhoStatus])
}
